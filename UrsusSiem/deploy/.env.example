# ============================================================================
# URSUS SIEM — Rust + Go microservices stack
# Copy this file to .env (next to docker-compose.yml) before running
# `docker compose up -d`
# ============================================================================

# ─── Authentication ───────────────────────────────────────────────────────
# JWT signing secret — any random 32+ char string
JWT_SECRET=change-me-to-a-random-32-character-string

# Initial admin (bcrypt password hash, generate with: see scripts/gen-password-hash.go)
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2a$12$replace.this.with.real.bcrypt.hash.generated.via.scripts

# API keys accepted on /api/ingest (comma-separated)
API_KEYS=agent-key-prod-1,agent-key-prod-2

# ─── Networking ───────────────────────────────────────────────────────────
# CORS allowed origins (comma-separated; * = allow all)
CORS_ORIGINS=*

# ─── PostgreSQL ───────────────────────────────────────────────────────────
# Override the default container password. Update DATABASE_URL accordingly.
POSTGRES_PASSWORD=logvault-secret
