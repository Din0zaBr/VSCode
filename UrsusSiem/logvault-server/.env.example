# === LogVault Configuration ===

# API keys for agent authentication (comma-separated for multiple agents)
API_KEYS=changeme-agent-key

# Server port on the host machine
SERVER_PORT=8000

# UI port on the host machine
UI_PORT=3000

# CORS origins (comma-separated, * = allow all)
CORS_ORIGINS=*

# PostgreSQL password
PG_PASSWORD=logvault-secret

# Database URL (used inside docker network, normally don't change)
DATABASE_URL=postgresql://logvault:logvault-secret@postgres:5432/logvault

# Max batch size for ingest endpoint
MAX_BATCH_SIZE=5000

# Number of recent events to keep in live WebSocket buffer
LIVE_BUFFER_SIZE=500

# === Alert Channels (optional) ===

# Webhook URL for alert notifications
ALERT_WEBHOOK_URL=

# Telegram Bot API token
ALERT_TELEGRAM_TOKEN=

# Telegram Chat ID for alerts
ALERT_TELEGRAM_CHAT_ID=

# === Agent Settings (for docker-compose.agent.yml) ===

# URL of the central LogVault server (IP or DNS)
SERVER_URL=http://192.168.1.10:8000

# Unique identifier for this agent
AGENT_ID=agent-01

# API key matching one from API_KEYS above
API_KEY=changeme-agent-key
