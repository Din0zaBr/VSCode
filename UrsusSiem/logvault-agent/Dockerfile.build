# ─────────────────────────────────────────────────────────────────────────────
# Linux PyInstaller build (produces a standalone ELF binary for Linux x86-64)
# Usage: bash build-in-docker.sh
#
# Windows binary: pywin32 cannot be cross-compiled; build natively on Windows:
#   pip install -r requirements-windows.txt pyinstaller
#   python Scripts/pywin32_postinstall.py -install
#   pyinstaller --onefile --name logvault-agent \
#       --hidden-import agent.src.readers.file_reader \
#       --hidden-import agent.src.readers.journald_reader \
#       --hidden-import agent.src.readers.winevent_reader \
#       --hidden-import win32evtlog --hidden-import win32evtlogutil \
#       --hidden-import win32con --hidden-import pywintypes \
#       --hidden-import pydantic --hidden-import yaml \
#       --paths . entrypoint.py
# ─────────────────────────────────────────────────────────────────────────────
FROM python:3.12-slim AS builder

RUN apt-get update && \
    apt-get install -y --no-install-recommends binutils && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /build

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt pyinstaller

COPY src/ ./agent/src/
RUN touch ./agent/__init__.py
COPY entrypoint.py .

RUN pyinstaller \
    --onefile \
    --name logvault-agent \
    --hidden-import agent.src.readers.file_reader \
    --hidden-import agent.src.readers.journald_reader \
    --hidden-import agent.src.transport.http \
    --hidden-import pydantic \
    --hidden-import yaml \
    --paths /build \
    entrypoint.py
