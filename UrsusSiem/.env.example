# URSUS SIEM - Environment Configuration
# Copy to .env and customize for your deployment

# ═══════════════════════════════════════════════════════════════════════════════
# PostgreSQL Database
# ═══════════════════════════════════════════════════════════════════════════════
POSTGRES_USER=logvault
POSTGRES_PASSWORD=logvault-secret
POSTGRES_DB=logvault

# ═══════════════════════════════════════════════════════════════════════════════
# Go API Gateway (logvault-go)
# ═══════════════════════════════════════════════════════════════════════════════
ADDR=:8080
DATABASE_URL=postgres://logvault:logvault-secret@postgres:5432/logvault

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
TOKEN_TTL_HOURS=8

# Admin Credentials
# Generate password hash with: echo -n "your-password" | go run golang.org/x/crypto/bcrypt
# Or use: https://bcrypt-generator.com/ (for development only!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2a$12$5FT9gQiPVsdNmOqv1B8rjuz3z2gNfmK0oqXnXG1nHn6CQb2iJN2p2

# Agent Ingestion API Keys (comma-separated)
API_KEYS=changeme-agent-key-1,changeme-agent-key-2

# Rust Engine Connection
ENGINE_URL=http://logvault-rust:8001

# CORS Origins (comma-separated, use * for development only)
CORS_ORIGINS=*

# Ingestion Limits
MAX_BATCH_SIZE=5000
LIVE_BUFFER_SIZE=500

# ═══════════════════════════════════════════════════════════════════════════════
# Rust Engine (logvault-rust)
# ═══════════════════════════════════════════════════════════════════════════════
ENGINE_ADDR=0.0.0.0:8001
RUST_LOG=info

# ═══════════════════════════════════════════════════════════════════════════════
# Frontend (UI) - Development
# ═══════════════════════════════════════════════════════════════════════════════
VITE_API_URL=http://localhost:8080
